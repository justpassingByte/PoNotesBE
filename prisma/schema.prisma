// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(uuid())
  email String @unique
}

model Platform {
  id      String   @id @default(uuid())
  name    String   @unique // e.g. "WPT Poker", "GG Poker"
  players Player[]
}

model Player {
  id               String   @id @default(uuid())
  platform_id      String
  name             String
  playstyle        String?
  aggression_score Int      @default(0)
  created_at       DateTime @default(now())
  
  // AI-generated fields (populated when ai_enabled = true)
  ai_playstyle        String?
  ai_aggression_level String?
  ai_aggression_score Int?
  ai_gto_baseline     String?
  ai_exploit_strategy String?
  ai_stats_used       String?   // JSON array of stat names used
  ai_analysis_mode    String?   // "simple" | "advanced"
  ai_range_matrix     Json?     // 13x13 mathematical range logic
  ai_action_breakdown Json?     // macro action %s (Raise, Call, Fold)
  ai_last_analyzed_at DateTime?

  platform         Platform      @relation(fields: [platform_id], references: [id])
  notes            Note[]
  stats            PlayerStats?
  analysis_contexts AnalysisContext[]

  @@unique([platform_id, name])
}

model Note {
  id         String   @id @default(uuid())
  player_id  String
  street     String
  note_type  String
  content    String
  source     String   @default("custom") // "template" | "custom"
  created_at DateTime @default(now())

  player     Player   @relation(fields: [player_id], references: [id])
}

model Template {
  id       String @id @default(uuid())
  label    String
  category String
  weight   Int    @default(0)
}

model PlayerStats {
  id              String @id @default(uuid())
  player_id       String @unique
  vpip            Float?
  rfi             Float?
  pfr             Float?
  three_bet       Float?
  fold_to_3bet    Float?
  cbet            Float?
  fold_to_cbet    Float?
  wtsd            Float?
  wsd             Float?
  aggression_freq Float?
  
  player          Player @relation(fields: [player_id], references: [id])
}

model AppSettings {
  id            String  @id @default("singleton")
  ai_enabled    Boolean @default(false)
  analysis_mode String  @default("simple") // "simple" | "advanced"
}

model AnalysisContext {
  id            String   @id @default(uuid())
  player_id     String
  position      String   // "IP" | "OOP"
  hero_stack    Float    // hero stack in BB
  villain_stack Float    // villain stack in BB
  created_at    DateTime @default(now())

  player        Player   @relation(fields: [player_id], references: [id])
}
